# Exclude files from Docker build context to speed up builds

# Git
.git
.gitignore
.gitattributes

# IDE
.vscode
.idea
*.swp
*.swo

# Testing
tests/
phpunit.xml
.phpunit.result.cache

# Documentation
README.md
CHANGELOG.md
docs/

# Node modules (if any)
node_modules/

# Environment
.env
.env.*
!.env.example

# Storage (will be mounted as volume)
storage/logs/*
storage/framework/cache/*
storage/framework/sessions/*
storage/framework/testing/*
storage/framework/views/*
!storage/.gitkeep
!storage/framework/.gitkeep

# Cache
bootstrap/cache/*
!bootstrap/cache/.gitkeep

# Vendor (will be installed via Composer)
vendor/

# Build artifacts
*.log
*.cache
